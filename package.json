{
  "name": "@salshah20/google-classroom-mcp",
  "version": "1.0.1",
  "description": "An MCP server that provides access to Google Classroom data through Claude and other AI assistants that support the MCP protocol.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "google-classroom-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "setup-auth": "tsc && node dist/setup-auth.js",
    "clean": "rmdir /s /q dist",
    "test": "npm run build && node dist/index.js",
    "auth": "npm run setup-auth",
    "prepublishOnly": "tsc && node inject-credentials.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SalShah20/classroom_mcp.git"
  },
  "keywords": [
    "mcp",
    "google-classroom",
    "claude",
    "ai",
    "model-context-protocol",
    "education"
  ],
  "author": "Saloni Shah",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@napi-rs/canvas": "^0.1.98",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pdf-parse": "^1.1.5",
    "better-sqlite3": "^12.9.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^140.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "onnxruntime-node": "^1.24.3",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "ppu-ocv": "^3.1.0",
    "ppu-paddle-ocr": "^5.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "bugs": {
    "url": "https://github.com/SalShah20/classroom_mcp/issues"
  },
  "homepage": "https://github.com/SalShah20/classroom_mcp#readme"
}
